{{$ID := "cticket_"}}
{{$DB := ""}}
{{$TChannel := ""}}
{{$TOwner := ""}}
{{$TState := ""}}
{{$TPower := ""}}
{{$TSubject := ""}}
{{$TCompose := ""}}
{{$TRateLimit := ""}}
{{$TLastReason := ""}}
{{$TTopMessage := ""}}
{{$TUsers := (cslice )}}
{{$THadUsers := (cslice )}}

{{try}}
	{{$DB = (dbGet .Channel.ID "TicketInfo").Value}}
	{{$TChannel = $DB.TChannel}}
	{{$TOwner = $DB.TOwner}}
	{{$TState = $DB.TState}}
	{{$TPower = $DB.TPower}}
	{{$TSubject = $DB.TSubject}}
	{{$TCompose = $DB.TCompose}}
    {{$TRateLimit = $DB.TRateLimit}}
	{{$TLastReason = $DB.TLastReason}}
	{{$TTopMessage = $DB.TTopMessage}}
	{{$TUsers = $DB.TUsers}}
	{{$THadUsers = $DB.THadUsers}}
{{catch}}
	{{/* Do Nothing */}}
{{end}}

{{$Flag := ""}}
{{ $Args := (len .CmdArgs) }}
{{ if eq $Args 1}}
	{{ $Flag = (lower (index .CmdArgs 0))}}
{{ end }}

{{$NoDBFound := print "I wasn't able to find any Database for this channel!"}}

{{$Create := cbutton "label" "Create Ticket" "custom_id" (print $ID "create") "emoji" (sdict "name" "📝") "style" "blue"}}
{{$Intro := cbutton "label" "What's This" "custom_id" (print $ID "intro") "emoji" (sdict "name" "ℹ️") "style" "grey"}}
{{if eq $Flag "setup"}}
	{{sendComponentMessage nil (componentBuilder "container" (sdict "components" (componentBuilder "text" (cslice "**Contact Staff - Privately**" "-# To create a ticket, Click the “📝 Create Ticket” button below. It'll open a private channel for you with server staff.") "separator" false "buttons" (cslice $Create $Intro))))}}
{{else if eq $Flag "top"}}
	{{if $TChannel}}
		{{sendMessage nil (complexMessage "embed" (cembed "description" (print "Here You Go: [" .Channel.Name "](<https://discord.com/channels/" .Guild.ID "/" $TChannel "/" $TTopMessage ">)") "color" 0xFFFFFF))}}
	{{else}}
		{{$NoDBFound}}
	{{end}}
{{else if eq $Flag "owner"}}
	{{if $TChannel}}
		{{sendMessage nil (complexMessage "embed" (cembed "description" (print "This ticket's Owner is <@" $TOwner ">.\n\n> -# You can copy UserID from footer.") "footer" (sdict "text" (print $TOwner)) "color" 0xFFFFFF))}}
	{{else}}
		{{$NoDBFound}}
	{{end}}
{{else if eq $Flag "state"}}
	{{if $TChannel}}
		{{sendMessage nil (complexMessage "embed" (cembed "description" (print "This ticket is in “" $TState "” state.") "color" 0xFFFFFF))}}
	{{else}}
		{{$NoDBFound}}
	{{end}}
{{else if eq $Flag "power"}}
	{{if $TChannel}}
		{{sendMessage nil (complexMessage "embed" (cembed "description" (print "This ticket is in under “" $TPower "” rule.") "color" 0xFFFFFF))}}
	{{else}}
		{{$NoDBFound}}
	{{end}}
{{else if eq $Flag "subject"}}
	{{if $TChannel}}
		{{$TTopEmbed := index (getMessage $TChannel $TTopMessage).Embeds 0}}
		{{sendMessage nil (complexMessage "embed" (cembed "title" $TTopEmbed.Title "description"  $TTopEmbed.Description "color"  $TTopEmbed.Color))}}
	{{else}}
		{{$NoDBFound}}
	{{end}}
{{else if eq $Flag "compose"}}
	{{if $TChannel}}
		{{$TTopEmbed := index (getMessage $TChannel $TTopMessage).Embeds 0}}
		{{sendMessage nil (complexMessage "embed" (cembed "title" $TTopEmbed.Title "description"  $TTopEmbed.Description "color"  $TTopEmbed.Color))}}
	{{else}}
		{{$NoDBFound}}
	{{end}}
{{else if eq $Flag "users"}}
	{{if $TChannel}}
		{{$Users := ""}}
		{{try}}
			{{range $TUsers}}
				{{$Users = (print $Users "<@" . ">\n")}}
			{{end}}
		{{catch}}
		{{end}}
		{{sendMessage nil (complexMessage "embed" (cembed "description" (print "Users who were added to this ticket:\n" $Users "-# Count: " (len $TUsers)) "color" 0xFFFFFF))}}
	{{else}}
		{{$NoDBFound}}
	{{end}}
{{else}}
    {{sendMessage .Channel.ID (componentBuilder "container" (sdict "color" 0xffaaaa "components" (componentBuilder "text" "> `setup`: To send Ticket Creator to current channel." "separator" true "text" "- `top`: To get the link of top message.\n- `owner`: To get the ticket owner\n- `state`: To get the ticket's state (Open/Close).\n- `power`: To see if ticket is AdminOnly,\n*staff≠AdminOnly*.\n- `subject`:  To get the link of top message.\n- `compose`:  To get the link of top message.\n- `users`: How many users were added to ticket.")))}}
{{end}}
